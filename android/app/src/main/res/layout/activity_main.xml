<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface_workspace">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="36dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/bubble_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_app_icon"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hero_title"
                    android:textColor="@color/ink"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hero_subtitle"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Overlay permission card -->
        <LinearLayout
            android:id="@+id/overlay_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_surface"
            android:padding="18dp"
            android:layout_marginTop="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_card_title"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_card_body"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/overlay_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    tools:text="Not granted" />

                <Button
                    android:id="@+id/overlay_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_grant"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:background="@drawable/button_primary"
                    android:paddingHorizontal="18dp"
                    android:minHeight="40dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

        <!-- Notification permission card -->
        <LinearLayout
            android:id="@+id/notif_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_surface"
            android:padding="18dp"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notif_card_title"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notif_card_body"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/notif_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    tools:text="Not granted" />

                <Button
                    android:id="@+id/notif_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_grant"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:background="@drawable/button_primary"
                    android:paddingHorizontal="18dp"
                    android:minHeight="40dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bubble controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_surface"
            android:padding="18dp"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bubble_card_title"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bubble_card_body"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/bubble_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    tools:text="Stopped" />

                <Button
                    android:id="@+id/bubble_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_start_bubble"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:background="@drawable/button_primary"
                    android:paddingHorizontal="18dp"
                    android:minHeight="40dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
